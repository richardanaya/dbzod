{
  "name": "database-validator-generator",
  "version": "0.0.0",
  "description": "Generate Zod schemas and JSDoc typedefs from database metadata.",
  "type": "module",
  "files": [
    "database-validator-generator.js",
    "database-validator-generator.test.js",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "database-validator-generator": "database-validator-generator.js",
    "dbvg": "database-validator-generator.js"
  },
  "scripts": {
    "start": "node ./database-validator-generator.js",
    "check": "node --check ./database-validator-generator.js",
    "test": "node --test",
    "prepack": "npm run check && npm test"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "zod",
    "schema",
    "validation",
    "cli",
    "jsdoc",
    "database"
  ],
  "dependencies": {
    "pg": "^8.13.1"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "zod": "^4.3.6"
  }
}
